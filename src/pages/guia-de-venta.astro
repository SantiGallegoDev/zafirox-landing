              </div>
              <div>
                <div class="text-2xl font-black text-gold">0%</div>
                <div class="text-[0.65rem] tracking-wider uppercase text-gray-400">comisión por cita</div>
              </div>
              <div>
                <div class="text-2xl font-black text-gold">&lt; 1h</div>
