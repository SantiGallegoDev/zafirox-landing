---
import SectionLabel from './SectionLabel.astro';
import { painpoints } from '../data/painpoints';

const icons: Record<string, string> = {
  'calendar-x': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="10" y1="14" x2="14" y2="18"/><line x1="14" y1="14" x2="10" y2="18"/></svg>',
  'clock': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
  'chart-down': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>',
};
---

<section id="problema" class="py-20 lg:py-28">
  <div class="max-w-7xl mx-auto px-5">
    <div class="fade-in">
      <SectionLabel number="01" text="El Problema" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-4">
        Tu barbería merece más<br class="hidden sm:block" /> que una libreta de citas
      </h2>
      <p class="text-gray-300 text-base lg:text-lg font-light max-w-xl leading-relaxed mb-12">
        Si todavía gestionas tu barbería con papel, WhatsApp o la memoria, estás perdiendo clientes y dinero cada día.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
      {painpoints.map((pain) => (
        <div class="fade-in group bg-gray-800 border border-gray-700 rounded-xl p-7 transition-all duration-400 hover:border-gold/20 hover:-translate-y-0.5 hover:shadow-[0_8px_40px_rgba(0,0,0,0.3)]">
          <div class="w-12 h-12 rounded-lg bg-gold-soft flex items-center justify-center text-gold mb-5" set:html={icons[pain.icon]} />
          <h3 class="text-lg font-bold mb-3 text-bone">{pain.title}</h3>
          <p class="text-gray-300 text-sm leading-relaxed">{pain.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
