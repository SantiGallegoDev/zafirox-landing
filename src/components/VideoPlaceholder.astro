<section class="relative py-16 lg:py-20 overflow-hidden">
  <div class="max-w-3xl mx-auto px-5">
    <div class="fade-in relative group cursor-pointer rounded-2xl overflow-hidden border border-gray-700 hover:border-gold/30 transition-all duration-500"
         onclick="window.open('https://wa.me/573000000000?text=Hola%2C%20quiero%20ver%20una%20demo%20de%20Zafirox', '_blank')">

      <!-- Dark gradient background simulating a video -->
      <div class="aspect-video bg-gradient-to-br from-carbon-light via-gray-800 to-carbon-light flex items-center justify-center relative">

        <!-- Decorative grid pattern -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(198,168,94,1) 1px, transparent 1px), linear-gradient(90deg, rgba(198,168,94,1) 1px, transparent 1px); background-size: 40px 40px;"></div>

        <!-- Play button -->
        <div class="relative z-10 flex flex-col items-center gap-4">
          <div class="relative">
            <!-- Pulsing rings -->
            <div class="absolute inset-0 rounded-full border-2 border-gold/30 animate-play-ring"></div>
            <div class="absolute inset-0 rounded-full border-2 border-gold/20 animate-play-ring" style="animation-delay: 0.5s;"></div>

            <!-- Play circle -->
            <div class="w-20 h-20 rounded-full bg-gold/10 border-2 border-gold/40 flex items-center justify-center group-hover:bg-gold/20 group-hover:border-gold/60 transition-all duration-300">
              <svg class="w-8 h-8 text-gold ml-1" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
          </div>
          <span class="text-gray-300 text-sm font-medium group-hover:text-bone transition-colors">
            Mira Zafirox en acción — 2 minutos
          </span>
        </div>

        <!-- Subtle gold glow at bottom -->
        <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-gold/5 to-transparent"></div>
      </div>
    </div>
  </div>
</section>
