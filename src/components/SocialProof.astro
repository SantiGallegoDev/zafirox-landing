---
import SectionLabel from './SectionLabel.astro';
import { testimonials, stats } from '../data/testimonials';
---

<section class="py-20 lg:py-28 border-t border-gray-700">
  <div class="max-w-7xl mx-auto px-5">
    <div class="fade-in text-center">
      <SectionLabel number="04" text="Resultados" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-16">
        Barberías que ya trabajan<br class="hidden sm:block" /> con nivel
      </h2>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-16 stagger">
      {stats.map((stat) => (
        <div class="fade-in text-center py-8 px-4 bg-gray-800 rounded-xl border border-gray-700">
          <div class="text-[clamp(2rem,4vw,3rem)] font-black text-gold leading-none mb-2" data-count={stat.value}>
            {stat.prefix || ''}{typeof stat.value === 'number' && stat.value % 1 !== 0 ? stat.value.toFixed(1) : stat.value.toLocaleString('es-CO')}{stat.suffix || ''}
          </div>
          <div class="text-gray-300 text-sm font-medium">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
      {testimonials.map((t) => (
        <div class="fade-in bg-gray-800 border border-gray-700 rounded-xl p-7 relative transition-all duration-400 hover:border-gold/20 hover:-translate-y-0.5">
          <!-- Quote mark -->
          <span class="absolute top-5 right-6 text-5xl font-serif text-gold/15 leading-none">&ldquo;</span>

          <p class="text-bone text-sm leading-relaxed mb-6 relative z-10">
            &ldquo;{t.quote}&rdquo;
          </p>

          <div class="border-t border-gray-700 pt-4">
            <p class="text-gold text-sm font-semibold">{t.name}</p>
            <p class="text-gray-400 text-xs">{t.business}, {t.location}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
