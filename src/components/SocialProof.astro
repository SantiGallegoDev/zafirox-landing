---
import SectionLabel from './SectionLabel.astro';
import { testimonials, stats } from '../data/testimonials';
---

<section class="relative py-20 lg:py-28 overflow-hidden">
  <div class="section-divider"></div>

  <!-- Background glow -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-0 w-[500px] h-[500px] bg-[radial-gradient(circle,rgba(198,168,94,0.03)_0%,transparent_70%)]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-5 relative z-10">
    <div class="fade-in text-center">
      <SectionLabel number="07" text="Resultados" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-16">
        Barberías que ya trabajan<br class="hidden sm:block" /> con nivel
      </h2>
    </div>

    <!-- Stats with counters -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-16 stagger scale-in" data-counter-group>
      {stats.map((stat) => (
        <div class="scale-in text-center py-8 px-4 bg-gray-800 rounded-xl border border-gray-700 border-t-2 border-t-gold/40 hover:border-t-gold transition-all duration-300 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-gold/5 to-transparent pointer-events-none"></div>
          <div class="relative z-10">
            <div class="text-[clamp(2rem,4vw,3rem)] font-black text-gold leading-none mb-2">
              <span data-count-to={stat.value} data-prefix={stat.prefix || ''} data-suffix={stat.suffix || ''}>
                {stat.prefix || ''}0{stat.suffix || ''}
              </span>
            </div>
            <div class="text-gray-300 text-sm font-medium">{stat.label}</div>
          </div>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 stagger">
      {testimonials.map((t) => (
        <div class="fade-in bg-gray-800 border border-gray-700 border-l-2 border-l-gold/30 rounded-xl p-7 relative transition-all duration-400 hover:border-gold/20 hover:-translate-y-0.5 hover:shadow-[0_0_30px_rgba(198,168,94,0.06)]">
          <!-- Stars -->
          <div class="flex gap-0.5 mb-4">
            {Array.from({length: t.rating}).map(() => (
              <svg class="w-3.5 h-3.5 text-gold" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>

          <!-- Quote mark -->
          <span class="absolute top-5 right-6 text-5xl font-serif text-gold/10 leading-none">&ldquo;</span>

          <p class="text-bone text-sm leading-relaxed mb-6 relative z-10">
            &ldquo;{t.quote}&rdquo;
          </p>

          <div class="border-t border-gray-700 pt-4 flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-gold/15 border border-gold/20 flex items-center justify-center">
              <span class="text-gold text-xs font-bold">{t.initials}</span>
            </div>
            <div>
              <p class="text-gold text-sm font-semibold">{t.name}</p>
              <p class="text-gray-400 text-xs">{t.business}, {t.location}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
