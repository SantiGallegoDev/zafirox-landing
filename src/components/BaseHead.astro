---
import { organizationSchema } from '../schemas/organization';
import { softwareSchema } from '../schemas/software-application';
import { faqSchema } from '../schemas/faq';
import { howToSchema } from '../schemas/howto';
import { offersSchema } from '../schemas/offers';

interface Props {
  title?: string;
  description?: string;
}

const BASE = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/';

const {
  title = 'Zafirox — Software de Agendamiento para Barberías, Salones, Tatuajes y más',
  description = 'Zafirox es la plataforma de agendamiento online para barberías, salones de belleza, estudios de tatuajes y todo negocio de servicios en Colombia. Agenda inteligente, WhatsApp automático y reportes. 3 días gratis. Desde $59.000/mes.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${BASE}og-image.png`, Astro.site).href;
---

<!-- Primary Meta Tags -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="keywords" content="software de agendamiento, agendamiento online, agenda barbería, agenda salón de belleza, software tatuajes, citas online Colombia, gestión de citas, agenda spa, software uñas, reservas online, app de citas, agenda online Colombia, Armenia Quindío" />
<meta name="author" content="Zafirox" />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />
<meta name="geo.region" content="CO-QUI" />
<meta name="geo.placename" content="Armenia, Quindío" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />

<!-- Font Preload -->
<link rel="preload" href={`${BASE}fonts/Montserrat-Variable-Latin.woff2`} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={`${BASE}fonts/Montserrat-Variable.woff2`} as="font" type="font/woff2" crossorigin />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:locale" content="es_CO" />
<meta property="og:site_name" content="Zafirox" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content="La plataforma que profesionaliza negocios de servicios: barberías, salones, tatuajes y más. 3 días gratis." />
<meta name="twitter:image" content={ogImage} />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(softwareSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
{offersSchema.map((offer) => (
  <script type="application/ld+json" set:html={JSON.stringify(offer)} />
))}
