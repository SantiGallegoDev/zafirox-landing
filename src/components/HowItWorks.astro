---
import SectionLabel from './SectionLabel.astro';

const steps = [
  {
    number: '01',
    title: 'Crea tu cuenta',
    description: 'Registra tu barbería, agrega tus servicios y tus barberos con foto. Listo en 10 minutos.',
  },
  {
    number: '02',
    title: 'Comparte tu link',
    description: 'Envía el link de tu página por WhatsApp o redes. Tu cliente elige servicio, barbero, día y hora.',
  },
  {
    number: '03',
    title: 'Controla todo',
    description: 'Recibe citas automáticamente, el cliente recibe confirmación por WhatsApp y tú ves todo en tu panel.',
  },
];
---

<section id="como-funciona" class="relative py-20 lg:py-28 bg-carbon-deep overflow-hidden">
  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto px-5">
    <div class="fade-in text-center">
      <SectionLabel number="05" text="Cómo Funciona" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-4">
        Tres pasos para organizar<br class="hidden sm:block" /> tu barbería
      </h2>
      <p class="text-gray-300 text-base lg:text-lg font-light max-w-xl mx-auto leading-relaxed mb-16">
        Empezar con Zafirox es más fácil que agendar una cita a mano.
      </p>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8 stagger">
      <!-- Connecting line (desktop) - animated -->
      <div class="hidden md:block absolute top-12 left-[16.66%] right-[16.66%] h-px overflow-hidden">
        <div class="h-full bg-gradient-to-r from-gold/40 via-gold to-gold/40 origin-left scale-x-0 transition-transform duration-[1.5s] ease-out" id="how-it-works-line"></div>
      </div>

      {steps.map((step, i) => (
        <div class="fade-in relative text-center">
          <!-- Number circle -->
          <div class="relative z-10 w-24 h-24 mx-auto mb-6 rounded-full bg-gray-800 border-2 border-gold/30 flex items-center justify-center transition-all duration-500 hover:border-gold hover:shadow-[0_0_20px_rgba(198,168,94,0.15)]">
            <span class="text-3xl font-black text-gold">{step.number}</span>
          </div>

          <h3 class="text-xl font-bold mb-3 text-bone">{step.title}</h3>
          <p class="text-gray-300 text-sm leading-relaxed max-w-xs mx-auto">{step.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Animate the connecting line on scroll -->
  <script>
    const line = document.getElementById('how-it-works-line');
    if (line) {
      const obs = new IntersectionObserver(([entry]) => {
        if (entry.isIntersecting) {
          line.style.transform = 'scaleX(1)';
        }
      }, { threshold: 0.3 });
      obs.observe(line.parentElement!);
    }
  </script>
</section>
