---
import GoldButton from './GoldButton.astro';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center text-center overflow-hidden pt-16">
  <!-- Animated gradient mesh background -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full bg-[radial-gradient(circle,rgba(198,168,94,0.07)_0%,transparent_70%)] animate-mesh-drift-1"></div>
    <div class="absolute bottom-1/4 right-1/3 w-[500px] h-[500px] rounded-full bg-[radial-gradient(circle,rgba(198,168,94,0.04)_0%,transparent_60%)] animate-mesh-drift-2"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-[radial-gradient(ellipse_at_center,rgba(198,168,94,0.03)_0%,transparent_60%)] animate-glow-pulse"></div>
    <!-- Top gold line -->
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/20 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-5">
    <!-- Badge -->
    <span class="inline-block text-[0.65rem] font-semibold tracking-[0.4em] uppercase text-gold border border-gold/30 px-6 py-2 rounded-full bg-gold/5 mb-10">
      Agendamiento y gestión para negocios de servicios
    </span>

    <!-- Logo wordmark -->
    <div class="text-[clamp(2.5rem,8vw,5rem)] font-black tracking-[0.15em] leading-none mb-6 bg-[linear-gradient(135deg,#F5F5F5_0%,#C6A85E_50%,#F5F5F5_100%)] bg-[length:200%_auto] bg-clip-text text-transparent animate-shimmer">
      ZAFIROX
    </div>

    <!-- Headline -->
    <h1 class="text-[clamp(1.8rem,5vw,3.5rem)] font-extrabold leading-[1.15] mb-6">
      Llena tu agenda.<br />
      <span class="text-gold">Cobra cada cita.</span>
    </h1>

    <!-- Subheadline with typing effect -->
    <p id="hero-subtitle" class="text-gray-300 text-[clamp(0.95rem,2vw,1.2rem)] font-light leading-relaxed max-w-2xl mx-auto mb-10 min-h-[3.5rem]">
      <span id="typed-text"></span><span id="typing-cursor" class="inline-block w-0.5 h-5 bg-gold/60 ml-0.5 align-middle animate-typing-cursor"></span>
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <GoldButton href="#contacto" size="lg">Probar gratis 3 días</GoldButton>
      <GoldButton href="#como-funciona" variant="ghost" size="lg">Ver cómo funciona</GoldButton>
    </div>

    <!-- Trust badges -->
    <div class="flex items-center justify-center gap-4 sm:gap-8 mt-8 flex-wrap">
      <div class="flex items-center gap-2 text-gray-400 text-xs">
        <svg class="w-4 h-4 text-gold/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
        <span>3 días gratis</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400 text-xs">
        <svg class="w-4 h-4 text-gold/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>Activo en 10 min</span>
      </div>
      <div class="flex items-center gap-2 text-gray-400 text-xs">
        <svg class="w-4 h-4 text-gold/60" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        <span>Cancela cuando quieras</span>
      </div>
    </div>

    <p class="mt-6 text-gray-400 text-sm tracking-wide">
      Sin tarjeta de crédito. Sin permanencia. Pago por Nequi o Daviplata.
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-400 text-[0.65rem] tracking-[0.2em] uppercase animate-float">
    <span>Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-gold to-transparent"></div>
  </div>

  <!-- Typing effect script -->
  <script>
    const text = "La plataforma que profesionaliza tu negocio. Agenda online, equipo, WhatsApp automático y reportes — en un solo lugar.";
    const target = document.getElementById('typed-text');
    const cursor = document.getElementById('typing-cursor');
    let i = 0;

    function type() {
      if (!target) return;
      if (i < text.length) {
        target.textContent += text.charAt(i);
        i++;
        setTimeout(type, 30);
      } else {
        setTimeout(() => { if (cursor) cursor.style.display = 'none'; }, 2000);
      }
    }

    setTimeout(type, 800);
  </script>
</section>
