---
import GoldButton from './GoldButton.astro';
---

<section class="relative min-h-screen flex items-center justify-center text-center overflow-hidden pt-16">
  <!-- Glow background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-[radial-gradient(ellipse_at_center,rgba(198,168,94,0.05)_0%,transparent_60%)] animate-glow-pulse"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto px-5">
    <!-- Badge -->
    <span class="inline-block text-[0.65rem] font-semibold tracking-[0.4em] uppercase text-gold border border-gold/30 px-6 py-2 rounded-full bg-gold/5 mb-10">
      Software de agendamiento para barberías
    </span>

    <!-- Logo wordmark -->
    <div class="text-[clamp(2.5rem,8vw,5rem)] font-black tracking-[0.15em] leading-none mb-6 bg-[linear-gradient(135deg,#F5F5F5_0%,#C6A85E_50%,#F5F5F5_100%)] bg-[length:200%_auto] bg-clip-text text-transparent animate-shimmer">
      ZAFIROX
    </div>

    <!-- Headline -->
    <h1 class="text-[clamp(1.8rem,5vw,3.5rem)] font-extrabold leading-[1.15] mb-6">
      Organiza tu barbería.<br />
      <span class="text-gold">Eleva tu nivel.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-gray-300 text-[clamp(0.95rem,2vw,1.2rem)] font-light leading-relaxed max-w-2xl mx-auto mb-10">
      La plataforma que transforma barberías en estudios profesionales.
      Agenda, clientes, barberos y reportes en un solo lugar.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <GoldButton href="#contacto" size="lg">Empezar ahora</GoldButton>
      <GoldButton href="#como-funciona" variant="ghost" size="lg">Ver cómo funciona</GoldButton>
    </div>

    <!-- Trust -->
    <p class="mt-10 text-gray-400 text-sm tracking-wide">
      Sin tarjeta de crédito. Sin compromisos. Pago por Nequi o Daviplata.
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-gray-400 text-[0.65rem] tracking-[0.2em] uppercase animate-float">
    <span>Scroll</span>
    <div class="w-px h-10 bg-gradient-to-b from-gold to-transparent"></div>
  </div>
</section>
