---
import SectionLabel from './SectionLabel.astro';
import { faq } from '../data/faq';
---

<section id="faq" class="relative py-20 lg:py-28 bg-carbon-deep overflow-hidden">
  <div class="section-divider"></div>

  <div class="max-w-3xl mx-auto px-5">
    <div class="fade-in text-center">
      <SectionLabel number="11" text="Preguntas Frecuentes" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-12">
        Resolvemos tus dudas
      </h2>
    </div>

    <div class="space-y-3 stagger">
      {faq.map((item) => (
        <details class="fade-in group bg-gray-800 border border-gray-700 rounded-xl transition-all duration-300 hover:border-gold/20 open:border-gold/30 open:border-l-2 open:border-l-gold">
          <summary class="flex items-center justify-between cursor-pointer px-6 py-5 text-bone font-semibold text-[0.95rem] list-none [&::-webkit-details-marker]:hidden select-none">
            <span>{item.question}</span>
            <svg class="w-5 h-5 text-gray-400 group-open:text-gold shrink-0 ml-4 transition-all duration-300 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </summary>
          <div class="grid grid-rows-[0fr] open:grid-rows-[1fr] transition-[grid-template-rows] duration-300">
            <div class="overflow-hidden">
              <div class="px-6 pb-5">
                <p class="text-gray-300 text-sm leading-relaxed">{item.answer}</p>
              </div>
            </div>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
