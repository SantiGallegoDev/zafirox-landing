---
import SectionLabel from './SectionLabel.astro';
import { pricing } from '../data/pricing';
---

<section id="precios" class="relative py-20 lg:py-28 overflow-hidden">
  <div class="section-divider"></div>

  <div class="max-w-7xl mx-auto px-5">
    <div class="fade-in text-center">
      <SectionLabel number="09" text="Planes y Precios" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-4">
        Elige el plan que se ajuste<br class="hidden sm:block" /> a tu negocio
      </h2>
      <p class="text-gray-300 text-base lg:text-lg font-light max-w-xl mx-auto leading-relaxed mb-6">
        7 días gratis. Sin contratos. Pagas mensual. Cancela cuando quieras.
      </p>

      <!-- Urgency banner -->
      <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-gold/10 border border-gold/20 mb-14">
        <span class="w-2 h-2 rounded-full bg-gold animate-pulse"></span>
        <span class="text-gold text-xs font-semibold tracking-wide">Precio de lanzamiento — cupos limitados</span>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start stagger">
      {pricing.map((tier) => (
        <div class:list={[
          'fade-in rounded-2xl p-8 relative transition-all duration-400 hover:shadow-[0_0_30px_rgba(198,168,94,0.06)]',
          tier.featured
            ? 'bg-gray-800 border-2 border-gold animate-border-pulse shadow-[0_0_40px_rgba(198,168,94,0.1)] md:-mt-4 md:mb-0'
            : 'bg-gray-800 border border-gray-700 hover:border-gold/20',
        ]}>
          {/* Featured badge with shimmer */}
          {tier.badge && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold text-carbon text-[0.65rem] font-bold tracking-[0.2em] uppercase px-4 py-1 rounded-full overflow-hidden">
              <span class="relative z-10">{tier.badge}</span>
              <span class="absolute inset-0 bg-[linear-gradient(135deg,transparent_30%,rgba(255,255,255,0.3)_50%,transparent_70%)] bg-[length:200%_auto] animate-shimmer"></span>
            </span>
          )}

          {/* Featured glow */}
          {tier.featured && (
            <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-gold/5 to-transparent pointer-events-none"></div>
          )}

          <div class="relative z-10">
            <h3 class="text-lg font-bold mb-4">{tier.name}</h3>

            <div class="mb-6">
              <span class="text-[clamp(2rem,4vw,2.8rem)] font-black text-bone">{tier.price}</span>
              <span class="text-gray-400 text-sm ml-1">{tier.period}</span>
            </div>

            <ul class="space-y-3 mb-8">
              {tier.features.map((feat) => (
                <li class="flex items-start gap-3 text-sm text-gray-300">
                  <svg class="w-5 h-5 text-gold shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {feat}
                </li>
              ))}
            </ul>

            <a
              href="#contacto"
              class:list={[
                'group relative block w-full text-center py-3.5 rounded-lg font-bold text-sm tracking-wider uppercase transition-all duration-300 overflow-hidden',
                tier.featured
                  ? 'bg-gold text-carbon hover:bg-[#d4b76a] hover:shadow-[0_4px_20px_rgba(198,168,94,0.3)] hover:scale-[1.02]'
                  : 'bg-transparent text-bone border border-gray-500 hover:border-gold hover:text-gold hover:scale-[1.02]',
              ]}
            >
              {tier.featured && (
                <span class="absolute inset-0 -translate-x-full group-hover:animate-shimmer-sweep bg-gradient-to-r from-transparent via-white/20 to-transparent pointer-events-none"></span>
              )}
              <span class="relative z-10">{tier.cta}</span>
            </a>
          </div>
        </div>
      ))}
    </div>

    <p class="fade-in text-center text-gray-400 text-sm mt-10">
      Pago por Nequi o Daviplata. Sin pasarela. Sin complicaciones.
    </p>
  </div>
</section>
