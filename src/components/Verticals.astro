---
import SectionLabel from './SectionLabel.astro';
import { verticals } from '../data/verticals';

const icons: Record<string, string> = {
  'scissors': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>',
  'sparkles': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3l1.9 5.8a2 2 0 0 0 1.3 1.3L21 12l-5.8 1.9a2 2 0 0 0-1.3 1.3L12 21l-1.9-5.8a2 2 0 0 0-1.3-1.3L3 12l5.8-1.9a2 2 0 0 0 1.3-1.3L12 3z"/><path d="M5 3v4"/><path d="M3 5h4"/><path d="M19 17v4"/><path d="M17 19h4"/></svg>',
  'needle': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 14.5 3 21"/><path d="M14 5 9 10l5 5 5-5-5-5z"/><path d="M19 5l2-2"/><path d="m10 9 5 5"/></svg>',
  'nail': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 14a4 4 0 0 1 8 0v5a2 2 0 0 1-2 2h-4a2 2 0 0 1-2-2v-5z"/><path d="M8 14c0-4 1.5-8 4-8s4 4 4 8"/><path d="M10 21h4"/></svg>',
  'spa': '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c0-5-3-9-9-9 0 5 3 9 9 9z"/><path d="M12 22c0-5 3-9 9-9 0 5-3 9-9 9z"/><path d="M12 22V8"/><path d="M12 8a4 4 0 0 0 4-4 4 4 0 0 0-4 4 4 4 0 0 0-4-4 4 4 0 0 0 4 4z"/></svg>',
};
---

<section id="para-quien" class="relative py-20 lg:py-28 overflow-hidden">
  <div class="section-divider"></div>

  <!-- Soft light halos for a less masculine / premium feel -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 right-1/4 w-[400px] h-[400px] rounded-full bg-[radial-gradient(circle,rgba(255,255,255,0.025)_0%,transparent_70%)]"></div>
    <div class="absolute bottom-0 left-1/4 w-[500px] h-[500px] rounded-full bg-[radial-gradient(circle,rgba(198,168,94,0.05)_0%,transparent_70%)]"></div>
  </div>

  <div class="max-w-7xl mx-auto px-5 relative z-10">
    <div class="fade-in text-center">
      <SectionLabel number="02" text="Para quién es Zafirox" />
      <h2 class="text-[clamp(1.8rem,4vw,2.8rem)] font-extrabold leading-tight mb-4">
        Hecho para negocios que<br class="hidden sm:block" />
        <span class="text-gold">trabajan por cita</span>
      </h2>
      <p class="text-gray-300 text-base lg:text-lg font-light max-w-2xl mx-auto leading-relaxed mb-14">
        Si tu equipo agenda, atiende y cobra por servicios, Zafirox se adapta a tu flujo. Sin importar la vertical.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 sm:gap-5 stagger">
      {verticals.map((v) => (
        <div class="fade-in group relative bg-gray-800 border border-gray-700 rounded-xl p-5 sm:p-6 transition-all duration-400 hover:border-gold/30 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(198,168,94,0.08)] hover:bg-white/[0.02]">
          <div class="w-11 h-11 rounded-lg bg-gold-soft flex items-center justify-center text-gold mb-4 transition-all duration-300 group-hover:bg-gold/20 group-hover:rotate-3" set:html={icons[v.icon]} />
          <h3 class="text-base font-bold mb-2 text-bone">{v.name}</h3>
          <p class="text-gray-400 text-xs leading-relaxed">{v.example}</p>
        </div>
      ))}
    </div>

    <!-- "Y más" message -->
    <div class="fade-in text-center mt-10">
      <p class="inline-flex items-center gap-2 text-gray-400 text-sm">
        <svg class="w-4 h-4 text-gold/70" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span>Y cualquier otro negocio de servicios que quiera tomar el control de su agenda.</span>
      </p>
    </div>
  </div>
</section>
